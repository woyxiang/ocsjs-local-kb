OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENBASE_URL=https://api.openai.com/v1

# 知识库模式：OFF | SEARCH（默认）
# OFF    - 关闭知识库，AI 直接回答（最快）
# SEARCH - AI 搜索相关章节后，结合章节内容回答（当前默认）
OPENAI_KB_MODE=SEARCH

# Embedding API（用于语义搜索）
EMBEDDING_BASE_URL=http://127.0.0.1:23456/v1
EMBEDDING_MODEL=text-embedding-3-small
